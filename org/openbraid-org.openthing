  },
  "x.org.memo_inbox": "memos/inbox/",
  "metadata": {
    "created_at": "2026-05-08",
    "created_by": "openbraid-director",
    "bootstrap_note": "Org charter scaffolded 2026-05-08 alongside repo init. Derives architectural posture from project_openbraid.md memory. v0 implementation pending; this charter will evolve as scope firms up post-build.",
    "related_projects": [
