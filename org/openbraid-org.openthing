        "contact": "openbraid-engineer@openbraid.app"
      }
    }
  ],
  "relationships": [
    {
      "type": "reports_to",
      "from": "openbraid-strategist",
      "to": "openbraid-director"
    },
    {
      "type": "reports_to",
      "from": "openbraid-engineer",
      "to": "openbraid-strategist"
    },
    {
      "type": "implements_for",
      "from": "openbraid-org",
      "to": {
        "id": "memodef-spec-org",
        "url": "https://github.com/memodef-spec/memodef/blob/main/org/memodef-spec.openthing"
      },
      "summary": "openbraid is a memodef:Memo implementation and conformance evidence point. Issues found while running openbraid feed back as proposals to memodef-spec."
    },
    {
      "type": "coordinates_with",
      "from": "openbraid-org",
      "to": {
        "id": "roledef-spec-org",
        "url": "https://github.com/roledef-spec/roledef/blob/main/org/roledef-spec.openthing"
      },
      "summary": "openbraid stores roledef references per role; schema changes in roledef affect storage shape."
    },
    {
      "type": "coordinates_with",
      "from": "openbraid-org",
      "to": {
        "id": "orgdef-spec-org",
        "url": "https://github.com/orgdef-spec/orgdef/blob/main/org/orgdef-spec.openthing"
      },
      "summary": "openbraid's account-contains-multiple-roles model is implicitly orgdef-shaped; coordinate conventions for personal-org charters."
    }
  ],
  "x.position.working_directory": {
    "openbraid-director": "https://github.com/openbraid-org/openbraid",
